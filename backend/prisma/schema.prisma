generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  LEARNER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SCENARIO
  ROLEPLAY
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ContentType {
  VIDEO
  PDF
  PPT
  SOP
  ARTICLE
  EMBED
}

enum InterventionType {
  REFRESHER_CONTENT
  NEW_QUIZ
  REMINDER
  MANAGER_ALERT
}

enum Language {
  EN
  HI
  TE
  TA
  KN
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  passwordHash   String
  name           String
  role           Role     @default(LEARNER)
  department     String?
  designation    String?
  managerId      Int?
  avatarUrl      String?
  isActive       Boolean  @default(true)
  language       Language   @default(EN)
  status         UserStatus @default(ACTIVE)
  inviteToken    String?    @unique
  inviteExpiry   DateTime?
  storeCode      String?
  region         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manager        User?    @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates   User[]   @relation("ManagerSubordinates")

  enrollments        Enrollment[]
  quizAttempts       QuizAttempt[]
  learningPaths      UserLearningPath[]
  badges             UserBadge[]
  streak             Streak?
  points             UserPoints?
  retentionScore     RetentionScore?
  riskProfile        RiskProfile?
  aiInteractions     AIInteraction[]
  watchSessions      WatchSession[]
  recommendations    LearningRecommendation[]
  interventions      LearningIntervention[]
  roleplays          RoleplaySessions[]

  @@index([managerId])
  @@index([role])
  @@index([department])
}

model Course {
  id              Int         @id @default(autoincrement())
  title           String
  description     String      @db.Text
  thumbnail       String?
  thumbnailS3Key  String?
  department      String?
  tags            String?
  estimatedHours  Float       @default(0)
  isPublished     Boolean     @default(false)
  createdById     Int
  titleHi        String?
  titleTe        String?
  descriptionHi  String?   @db.Text
  descriptionTe  String?   @db.Text
  isMandatory    Boolean   @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  modules         Module[]
  enrollments     Enrollment[]
  quizzes         Quiz[]
  learningPathCourses LearningPathCourse[]
  recommendations LearningRecommendation[]
  certifications  CertificationCourse[]

  @@index([department])
  @@index([isPublished])
}

model Module {
  id          Int         @id @default(autoincrement())
  courseId    Int
  title       String
  titleHi        String?
  titleTe        String?
  description String?
  contentUrl  String   @db.Text
  order       Int
  contentType ContentType
  s3Key       String?
  duration    Int         @default(0)
  aiSummary      String?     @db.Text
  thumbnail      String?
  thumbnailS3Key String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  watchSessions WatchSession[]
  flashcards   Flashcard[]

  @@index([courseId])
}

model Enrollment {
  id             Int       @id @default(autoincrement())
  userId         Int
  courseId       Int
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?
  progressPercent Float    @default(0)
  lastAccessedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model WatchSession {
  id           Int      @id @default(autoincrement())
  userId       Int
  moduleId     Int
  watchedSecs  Int      @default(0)
  totalSecs    Int
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moduleId])
}

model Quiz {
  id          Int        @id @default(autoincrement())
  courseId    Int?
  title       String
  description String?
  timeLimit   Int?
  passingScore Int       @default(70)
  isAIGenerated Boolean  @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course    Course?      @relation(fields: [courseId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
}

model Question {
  id           Int          @id @default(autoincrement())
  quizId       Int
  text         String       @db.Text
  type         QuestionType
  difficulty   Difficulty   @default(MEDIUM)
  options      Json?
  correctAnswer String
  explanation  String?      @db.Text
  points       Int          @default(10)
  order        Int

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizAttempt {
  id          Int       @id @default(autoincrement())
  userId      Int
  quizId      Int
  score       Float
  totalPoints Int
  timeTaken   Int?
  completedAt DateTime  @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz    Quiz         @relation(fields: [quizId], references: [id])
  answers QuizAnswer[]

  @@index([userId])
  @@index([quizId])
}

model QuizAnswer {
  id          Int     @id @default(autoincrement())
  attemptId   Int
  questionId  Int
  answer      String
  isCorrect   Boolean

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@index([attemptId])
}

model LearningPath {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  department  String?
  isAIGenerated Boolean @default(false)
  createdAt   DateTime @default(now())

  courses     LearningPathCourse[]
  userPaths   UserLearningPath[]
}

model LearningPathCourse {
  id             Int @id @default(autoincrement())
  learningPathId Int
  courseId       Int
  order          Int

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id])

  @@unique([learningPathId, courseId])
}

model UserLearningPath {
  id             Int       @id @default(autoincrement())
  userId         Int
  learningPathId Int
  assignedAt     DateTime  @default(now())
  completedAt    DateTime?
  progressPercent Float    @default(0)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPath LearningPath @relation(fields: [learningPathId], references: [id])

  @@unique([userId, learningPathId])
}

model Badge {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String
  iconUrl     String?
  category    String
  criteria    Json

  userBadges UserBadge[]
}

model UserBadge {
  id        Int      @id @default(autoincrement())
  userId    Int
  badgeId   Int
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Streak {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPoints {
  id            Int @id @default(autoincrement())
  userId        Int @unique
  totalPoints   Int @default(0)
  weeklyPoints  Int @default(0)
  monthlyPoints Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RetentionScore {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  score           Float    @default(0)
  quizAccuracy    Float    @default(0)
  watchCompletion Float    @default(0)
  revisionFreq    Float    @default(0)
  streakBonus     Float    @default(0)
  aiInteraction   Float    @default(0)
  calculatedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RiskProfile {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  riskLevel       RiskLevel @default(LOW)
  retentionScore  Float     @default(100)
  daysInactive    Int       @default(0)
  failedQuizzes   Int       @default(0)
  recommendation  String?   @db.Text
  calculatedAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIInteraction {
  id        Int      @id @default(autoincrement())
  userId    Int
  sessionId String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}

model LearningRecommendation {
  id         Int      @id @default(autoincrement())
  userId     Int
  courseId   Int?
  reason     String   @db.Text
  priority   Int      @default(1)
  isActedOn  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])

  @@index([userId])
}

model LearningIntervention {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      InterventionType
  reason    String
  isActedOn Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Flashcard {
  id        Int    @id @default(autoincrement())
  moduleId  Int
  front     String @db.Text
  back      String @db.Text
  order     Int

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model RoleplaySessions {
  id                 Int      @id @default(autoincrement())
  userId             Int
  scenario           String
  transcript         Json
  productScore       Float?
  confidenceScore    Float?
  communicationScore Float?
  upsellScore        Float?
  overallScore       Float?
  feedback           String?  @db.Text
  strengths          Json?    // Added to store evaluated strengths array
  improvements       Json?    // Added to store evaluated improvements array
  completedAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SkillScore {
  id        Int      @id @default(autoincrement())
  userId    Int
  skill     String
  score     Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, skill])
  @@index([userId])
}

model Certification {
  id                   Int      @id @default(autoincrement())
  name                 String
  description          String?  @db.Text
  minQuizScore         Int      @default(70)
  minCourseCompletion  Int      @default(80)
  isActive             Boolean  @default(true)
  createdById          Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  courses CertificationCourse[]

  @@index([isActive])
}

model CertificationCourse {
  id              Int @id @default(autoincrement())
  certificationId Int
  courseId        Int

  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  course        Course        @relation(fields: [courseId], references: [id])

  @@unique([certificationId, courseId])
}

model DocmostDocument {
  id           Int      @id @default(autoincrement())
  docmostId    String   @unique
  title        String
  content      String   @db.LongText
  spaceId      String?
  embeddingId  String?
  chunkCount   Int      @default(0)
  lastSyncedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([spaceId])
}
